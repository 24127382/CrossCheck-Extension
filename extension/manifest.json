{
  "manifest_version": 3,
  "name": "CrossCheck - Fact Checker",
  "version": "0.1.0",
  "description": "Browser extension for real-time fact-checking of claims",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CrossCheck - Fact Checker"
  }
}
